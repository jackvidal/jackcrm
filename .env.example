# ═══════════════════════════════════════════════════════════════════════════
# JackCRM — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ═══════════════════════════════════════════════════════════════════════════


# ─── Supabase (Project Settings → API Keys) ────────────────────────────────

# From the top of the API Keys page (or "Connect" button → App Frameworks):
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# The "Publishable key" (sb_publishable_...) — safe for the browser:
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# The "Secret key" (sb_secret_...) — server-only, NEVER exposed to client:
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...


# ─── Database (Connect button → ORMs → Prisma) ─────────────────────────────
# Both strings have a [YOUR-PASSWORD] placeholder — replace it with the
# database password you set when creating the Supabase project.
# URL-ENCODE the password if it contains & @ # : ? / (e.g. & → %26, @ → %40).
# Easier alternative: reset the DB password to alphanumeric only.

# Pooled connection (port 6543) — used by the running app:
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (port 5432) — used by Prisma migrations:
DIRECT_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres


# ─── Anthropic (console.anthropic.com → API Keys) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6


# ─── Cal.com webhook (Cal.com → Settings → Developer → Webhooks) ───────────
# Generate a fresh secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Paste the same value into the Cal.com webhook config and into Vercel env.
CAL_WEBHOOK_SECRET=whsec_...


# ─── Wassender (WhatsApp) ──────────────────────────────────────────────────
# Personal Access Token is NOT stored here — it's per-user (Profile.wassenderToken).
# Only the webhook signing secret lives in env, for the incoming webhook handler.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Paste the same value into the Wassender webhook config (Webhook Settings → Secret)
# and into Vercel env. If unset, the webhook accepts any payload (dev only — DO NOT
# leave unset in production).
WASSENDER_WEBHOOK_SECRET=whsec_...

# (Optional) Override the Wassender base URL — defaults to https://wasenderapi.com/api
# WASSENDER_API_URL=https://wasenderapi.com/api


# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
